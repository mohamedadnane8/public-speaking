# API Configuration
# The base URL of the .NET backend API
VITE_API_BASE_URL=http://165.232.89.236:5000

# Note: Google OAuth is now handled entirely by the backend.
# No VITE_GOOGLE_CLIENT_ID needed in the frontend anymore.
# The backend endpoints are:
#   - GET /api/auth/google/login     - Start OAuth flow (redirects to Google)
#   - GET /api/auth/google/callback  - OAuth callback (backend handles this)
#   - GET /api/auth/me               - Get current user (requires auth cookie)
#   - POST /api/auth/refresh         - Refresh access token
#   - POST /api/auth/logout          - Logout and clear cookies
